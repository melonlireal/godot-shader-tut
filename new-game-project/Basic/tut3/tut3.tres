code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D tex_frg_8;
uniform sampler2D tex_frg_3;
uniform sampler2D tex_frg_6;



void fragment() {
// Texture2D:8
	vec4 n_out8p0 = texture(tex_frg_8, UV);


// Input:9
	vec4 n_out9p0 = COLOR;


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, UV);


// Step:5
	float n_in5p0 = 0.30000;
	float n_out5p0 = step(n_in5p0, n_out3p0.x);


// Mix:11
	vec3 n_out11p0 = mix(vec3(n_out8p0.xyz), vec3(n_out9p0.xyz), vec3(n_out5p0));


// Texture2D:6
	vec4 n_out6p0 = texture(tex_frg_6, UV);


// FloatFunc:7
	float n_out7p0 = 1.0 - n_out6p0.x;


// Output:0
	COLOR.rgb = n_out11p0;
	COLOR.a = n_out7p0;


}
"
